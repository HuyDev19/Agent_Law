# Copy file này thành .env và điền API Key của bạn
# cp .env.example .env

# ===== BẮTBUỘC =====
# Lấy tại: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=paste_your_gemini_api_key_here

# ===== CHROMADB CONFIGURATION =====
# Sử dụng Local Mode (Recommended) - Không cần Cloud credentials
# ChromaDB sẽ lưu dữ liệu trong thư mục DATABASE_PATH
DATABASE_PATH=database

# ===== DATA CONFIGURATION =====
DATA_PATH=data

# ===== EMBEDDING CONFIGURATION =====
EMBEDDING_MODEL=keepitreal/vietnamese-sbert

# ===== LLM CONFIGURATION =====
LLM_MODEL=gemini-pro
LLM_TEMPERATURE=0

# ===== APPLICATION CONFIGURATION =====
APP_TITLE=Agent Tra Cứu Luật Pháp Việt Nam
DEBUG=False

# ===== NOTES =====
# ChromaDB Update (June 2026):
# - Cách cũ (CloudClient, Client with Settings) đã deprecated
# - Sử dụng PersistentClient (cách mới, recommended)
# - Dữ liệu được lưu local trong thư mục DATABASE_PATH
# - Không cần Chroma Cloud credentials
